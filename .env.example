DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_COOKIES=false
DJANGO_SSL_REDIRECT=false
DJANGO_HSTS_SECONDS=0
TIME_ZONE=America/Los_Angeles
INITIAL_SETUP_TOKEN=replace-with-one-time-random-token
DATABASE_URL=postgresql://kuratorr:change-me@db:5432/kuratorr
CELERY_BROKER_URL=redis://redis:6379/0
POSTGRES_DB=kuratorr
POSTGRES_USER=kuratorr
POSTGRES_PASSWORD=change-me
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
LASTFM_API_KEY=
YOUTUBE_API_KEY=
HTTP_USER_AGENT=Kuratorr/1.0 (your-email@example.com)
MUSIC_MOUNT_HOST=/path/to/music
LIBRARY_BROWSE_MOUNT_HOST=/path/containing/music-libraries
PLAYLIST_MOUNT_HOST=/path/to/playlists
